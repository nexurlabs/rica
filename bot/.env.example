# =============================================================================
# Rica Bot - Environment Variables (Self-Hosted Local Mode)
# =============================================================================
# For a basic local setup, you don't need any of these.
# Rica works fully with just the config.yaml generated during onboarding.

# Discord Bot Token (from Discord Developer Portal)
# Set via onboarding — stored in ~/.rica/config.yaml
DISCORD_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Optional: AI Provider API keys
# These can also be set via the dashboard UI after onboarding.
# ---------------------------------------------------------------------------

# Google AI (Gemini) — https://aistudio.google.com/app/apikey
# GOOGLE_AI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Groq — https://console.groq.com/keys
# GROQ_API_KEY=


